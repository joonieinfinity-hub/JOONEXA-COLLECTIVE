rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isFounder() {
      return isAuthenticated() && 
        request.auth.token.email == "rimi@joonexa-collective.com";
    }

    // Site Settings - Publicly readable, only founders can edit
    match /siteSettings/main {
      allow read: if true;
      allow write: if isFounder();
    }

    // Portfolio - Publicly readable, only founders can edit
    match /portfolio/{itemId} {
      allow read: if true;
      allow write: if isFounder();
    }

    // Pricing - Publicly readable, only founders can edit
    match /pricing/main {
      allow read: if true;
      allow write: if isFounder();
    }
    
    // Default deny for everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
